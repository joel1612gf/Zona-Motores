[debug] [2026-03-27T03:51:33.668Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/studio-2511212328-1383b/rulesets {"name":"projects/studio-2511212328-1383b/rulesets/46745f99-49fd-4e1a-98e6-0b4c1b277c7b","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n    \n    function isAdmin() {\n      return request.auth != null && request.auth.token.email == 'zonamotores.ve@gmail.com';\n    }\n\n    // Concesionarios - public read for business login\n    match /concesionarios/{concesionarioId} {\n      allow read: if true;\n      allow write: if true;\n      \n      match /staff/{staffId} {\n        allow read: if true;\n        allow write: if true;\n      }\n      \n      match /{subcollection}/{docId} {\n        allow read: if true;\n        allow write: if true;\n      }\n    }\n\n    match /users/{userId} {\n      // User profiles are public to read for dealership pages and listing details.\n      // Phone numbers are already public within vehicle listings.\n      allow get, list: if true;\n      // Only the owner or an admin can make changes to their own profile.\n      allow write: if isOwner(userId) || isAdmin();\n\n      // Vehicle listings are a subcollection of users\n      match /vehicleListings/{listingId} {\n        // Anyone can get a single listing\n        allow get: if true;\n        \n        // Only the owner of the user document or an admin can create or delete their own listings\n        // OR allow SaaS Business to sync vehicles without Firebase Auth\n        allow create: if isOwner(userId) || isAdmin() || (request.resource.data.seller.isSaaSBusiness == true && request.resource.data.seller.uid == userId);\n        \n        allow delete: if isOwner(userId) || isAdmin() || (resource.data.seller.isSaaSBusiness == true && resource.data.seller.uid == userId);\n        \n        // For updates:\n        // 1. The owner or an admin can update any field.\n        // 2. Any user can update ONLY the 'viewCount' or 'contactRequests' fields.\n        // 3. SaaS Business can update \n        allow update: if (isOwner(userId) || isAdmin()) ||\n                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) ||\n                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactRequests']) ||\n                       (request.resource.data.seller.isSaaSBusiness == true && request.resource.data.seller.uid == userId);\n      }\n\n      match /favorites/{vehicleId} {\n        // A user can only manage their own favorites\n        allow read, write, delete: if isOwner(userId);\n      }\n      \n      match /subscription/{subscriptionId} {\n        // A user can only manage their own subscription\n        allow read, write: if isOwner(userId);\n      }\n\n      match /notifications/{notificationId} {\n        // A user can only read and manage their own notifications\n        allow read, write: if isOwner(userId);\n      }\n    }\n\n    // This rule allows a collection group query on 'vehicleListings'.\n    // It's required to let anyone list all vehicles across all users.\n    // A composite index will need to be created in Firestore for this to work.\n    match /{path=**}/vehicleListings/{listingId} {\n      allow list: if true;\n    }\n\n    // This collection is no longer used, so we deny all access to prevent confusion.\n    match /vehicle_listings/{listingId} {\n      allow read, write: if false;\n    }\n\n    // vehicle_meta can be read by anyone\n    match /vehicle_meta/{docId} {\n      allow get, list: if true;\n    }\n\n    // exchangeRates can be read by anyone\n    match /exchangeRates/{rateId} {\n        allow get, list: if true;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-27T03:51:33.765039Z","metadata":{"services":["cloud.firestore"]}}
