          bcvRate={tasaCambio}
          monthLabel={['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'][selectedMonth]}
          year={selectedYear}
          defaultCommissionPercentage={concesionario?.configuracion.estructura_comision}
        />
      )}
    </div>
  );
}
