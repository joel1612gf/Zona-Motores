      {/* Staff Detail Modal */}
      {selectedStaff && (
        <StaffCommissionModal 
          staffMember={selectedStaff}
          sales={sales?.filter(s => s.vendedor_staff_id === selectedStaff.id) || []}
          open={!!selectedStaff}
