                )}
              </div>
            </div>
          </CardContent>
          {!isReadOnly && !marketplaceLinkedEmail && (
            <CardFooter className="bg-background/50 border-t justify-end py-4">
              <Button onClick={handleLinkMarketplace} disabled={isLinkingMarketplace || !marketplaceEmail || !marketplacePassword}>
