<file path="firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'zonamotores.ve@gmail.com';
    }

    // Concesionarios - public read for business login
    match /concesionarios/{concesionarioId} {
      allow read: if true;
      allow write: if true;
      
      match /staff/{staffId} {
        allow read: if true;
        allow write: if true;
      }
      
      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if true;
      }
    }

    match /users/{userId} {
      // User profiles are public to read for dealership pages and listing details.
      // Phone numbers are already public within vehicle listings.
      allow get, list: if true;
      // Only the owner or an admin can make changes to their own profile.
      allow write: if isOwner(userId) || isAdmin();

      // Vehicle listings are a subcollection of users
      match /vehicleListings/{listingId} {
        // Anyone can get a single listing
        allow get: if true;
        
        // Only the owner of the user document or an admin can create or delete their own listings
        // OR allow SaaS Business to sync vehicles without Firebase Auth
        allow create: if isOwner(userId) || isAdmin() || (request.resource.data.seller.isSaaSBusiness == true && request.resource.data.seller.uid == userId);
        
        allow delete: if isOwner(userId) || isAdmin() || (resource.data.seller.isSaaSBusiness == true && resource.data.seller.uid == userId);
        
        // For updates:
        // 1. The owner or an admin can update any field.
        // 2. Any user can update ONLY the 'viewCount' or 'contactRequests' fields.
        // 3. SaaS Business can update 
        allow update: if (isOwner(userId) || isAdmin()) ||
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) ||
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['contactRequests']) ||
                       (request.resource.data.seller.isSaaSBusiness == true && request.resource.data.seller.uid == userId);
      }

      match /favorites/{vehicleId} {
        // A user can only manage their own favorites
        allow read, write, delete: if isOwner(userId);
      }
      
      match /subscription/{subscriptionId} {
        // A user can only manage their own subscription
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        // A user can only read and manage their own notifications
        allow read, write: if isOwner(userId);
      }
    }

    // This rule allows a collection group query on 'vehicleListings'.
    // It's required to let anyone list all vehicles across all users.
    // A composite index will need to be created in Firestore for this to work.
    match /{path=**}/vehicleListings/{listingId} {
      allow list: if true;
    }

    // This collection is no longer used, so we deny all access to prevent confusion.
    match /vehicle_listings/{listingId} {
      allow read, write: if false;
    }

    // vehicle_meta can be read by anyone
    match /vehicle_meta/{docId} {
      allow get, list: if true;
    }

    // exchangeRates can be read by anyone
    match /exchangeRates/{rateId} {
        allow get, list: if true;
    }
  }
}
</file>

