          >
            <ChevronDown className="h-4 w-4" /> Cargar más registros
          </Button>
        </div>
      )}

      {printData && type === 'EXPENSE' && (
        <ExpensePrint 
          printMode={printMode} 
          concesionario={concesionario} 
          expenseData={printData} 
        />
      )}
      
      {printData && type !== 'EXPENSE' && (
        <FiscalNotePrint 
          printMode={printMode} 
          concesionario={concesionario} 
          noteData={printData} 
        />
      )}
    </div>
  );
}
