        <div className="md:col-span-1 space-y-6">
          <Skeleton className="h-64 w-full" />
          <Skeleton className="h-80 w-full" />
        </div>
      </div>
    </div>
  );
}

export default function ListingDetailPage() {
  return (
    <MapsProvider>
      <ListingDetailContent />
    </MapsProvider>
  );
