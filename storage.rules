rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read for all files in the bucket.
    match /{allPaths=**} {
      allow read: if true;
    }

    // TEMPORARY DIAGNOSTIC RULE: Allow any authenticated user to write.
    // This is NOT secure and will be reverted.
    // It's used to isolate if the 'request.auth.uid == userId' check is the point of failure.
    match /vehicle-images/{userId}/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
