rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This rule allows anyone to read images from the listings path.
    // This is necessary for public visitors to see vehicle photos.
    match /listings/{userId}/{listingId}/{allPaths=**} {
      allow read: if true;
    }

    // This rule allows an authenticated user to write (upload, update, delete)
    // images, but only to a path that matches their own user ID.
    // This prevents a user from maliciously modifying another user's listing photos.
    match /listings/{userId}/{listingId}/{imageName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
