rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read for all files.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to write to their own folder within 'vehicle-images'.
    match /vehicle-images/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /dealer-assets/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow uploads for business branding (Logo/Banner)
    match /business-assets/{businessId}/{allPaths=**} {
      allow read: if true;
      allow write: if true; // In the future, restrict to authenticated business sessions
    }
  }
}
