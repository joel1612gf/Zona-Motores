rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read for all files in the bucket.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to write to their own folder within 'Zona motores'.
    match /"Zona motores"/vehicle-images/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
